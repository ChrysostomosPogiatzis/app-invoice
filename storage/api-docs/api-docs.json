    "/api/sync/contacts": {
      "post": {
        "tags": ["Sync"],
        "summary": "Bulk import phone contacts from a mobile device",
        "description": "Upserts contacts by phone number match (last 8 digits). Skips soft-deleted contacts. Rate-limited to 10 req/min.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": ["contacts"],
                "type": "object",
                "properties": {
                  "contacts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["name","phone"],
                      "properties": {
                        "name":  { "type": "string" },
                        "phone": { "type": "string" },
                        "email": { "type": "string", "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Sync result", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "imported": { "type": "integer" }, "updated": { "type": "integer" } } } } } },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/sync/logs": {
      "post": {
        "tags": ["Sync"],
        "summary": "Bulk import call logs from a mobile device",
        "description": "Deduplicates by phone + date + type. Supports Unix timestamps (ms and s). Accepts type aliases: `incoming` → `inbound`, `outgoing` → `outbound`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": ["logs"],
                "type": "object",
                "properties": {
                  "logs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["phone","date"],
                      "properties": {
                        "phone":    { "type": "string" },
                        "type":     { "type": "string", "enum": ["inbound","outbound","missed","incoming","outgoing"], "nullable": true },
                        "duration": { "type": "integer", "nullable": true, "description": "Seconds" },
                        "date":     { "type": "string",  "description": "ISO 8601 or Unix timestamp (ms or s)" },
                        "notes":    { "type": "string",  "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Sync result", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "processed": { "type": "integer" }, "skipped": { "type": "integer" } } } } } }
        }
      }
    },
    "/api/banking/sync": {
      "post": {
        "tags": ["Banking"],
        "summary": "Trigger a manual bank synchronisation for all active connections",
        "description": "Rate-limited to 5 req/min. Returns immediately — sync runs asynchronously via queue.",
        "responses": {
          "200": { "description": "Sync queued", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Sync queued." } } } } } }
        }
      }
    }
  }
